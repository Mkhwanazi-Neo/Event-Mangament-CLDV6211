@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<style>
    body {
        background: url('/images/poolroomLarge.png') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Segoe UI', Tahoma, sans-serif;
    }

    .event-header {
        color: #007FFF;
        text-shadow: 1px 1px 0px #fff, 2px 2px 5px rgba(0,0,0,0.1);
        font-weight: 900;
        margin-top: 40px;
    }

    /* Glass Container */
    .glass-panel {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 25px;
        padding: 40px;
        margin-bottom: 50px;
        box-shadow: 0 10px 30px rgba(0, 127, 255, 0.1);
    }

    /* Modern 2000s List Items */
    .event-row {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 15px;
        margin-bottom: 15px;
        padding: 20px;
        transition: all 0.3s ease;
        border-left: 5px solid #007FFF;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .event-row:hover {
            transform: scale(1.02);
            background: rgba(255, 255, 255, 0.5);
            box-shadow: 0 5px 15px rgba(0, 127, 255, 0.2);
        }

    .event-date-box {
        background: white;
        color: #007FFF;
        padding: 10px;
        border-radius: 12px;
        text-align: center;
        min-width: 80px;
        font-weight: bold;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .event-info {
        flex-grow: 1;
        padding-left: 25px;
    }

    .event-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #004a99;
        margin: 0;
    }

    .event-desc {
        font-size: 0.9rem;
        color: #555;
        margin-top: 5px;
    }

    .venue-tag {
        font-size: 0.8rem;
        color: #007FFF;
        font-weight: 600;
        text-transform: uppercase;
    }

    /* Glossy Create Button */
    .btn-glass-blue {
        background: linear-gradient(180deg, #4da6ff 0%, #007FFF 50%, #005fbf 100%);
        color: white !important;
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: bold;
        text-decoration: none;
        display: inline-block;
        box-shadow: 0 4px 15px rgba(0,127,255,0.3);
    }

    .action-btns a {
        color: #007FFF;
        font-size: 0.85rem;
        font-weight: 700;
        margin-left: 10px;
        text-decoration: none;
    }

        .action-btns a:hover {
            text-decoration: underline;
        }
</style>

<div class="container">
    <div class="d-flex justify-content-between align-items-center">
        <h1 class="event-header">Upcoming Events</h1>
        <a asp-action="Create" class="btn-glass-blue">+ New Event</a>
    </div>

    <div class="glass-panel">
        @foreach (var item in Model)
        {
            <div class="event-row">
                <div class="event-date-box">
                    <div style="font-size: 0.7rem;">@item.EventDate.ToString("MMM")</div>
                    <div style="font-size: 1.5rem; line-height: 1;">@item.EventDate.ToString("dd")</div>
                    <div style="font-size: 0.7rem;">@item.EventDate.ToString("yyyy")</div>
                </div>

                <div class="event-info">
                    <span class="venue-tag">@@ @Html.DisplayFor(modelItem => item.Venue.Location)</span>
                    <h3 class="event-name">@item.EventName</h3>
                    <p class="event-desc">@item.Description</p>
                </div>

                <div class="action-btns">
                    <a asp-action="Edit" asp-route-id="@item.EventID">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.EventID">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.EventID">Delete</a>
                </div>
            </div>
        }
    </div>
</div>