@{
    ViewData["Title"] = "Home Page";
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EventEase Management Company</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
    <style>
            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                /* Replace 'your-image-path.jpg' with the actual link to your image */
                background: url('/images/homePg.jpg') no-repeat center center fixed;
                background-size: cover;
                color: #333;
                min-height: 100vh;
            }

            /* 2000s Glossy Navbar */
            .navbar {
                background: rgba(255, 255, 255, 0.2);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.3);
                box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
            }

            .navbar-brand {
                font-weight: 800;
                color: #007FFF !important;
                text-shadow: 1px 1px 2px rgba(255, 255, 255, 0.8);
            }

            /* Glassmorphism Jumbotron */
            .jumbotron {
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                border: 1px solid rgba(255, 255, 255, 0.4);
                border-radius: 20px;
                margin-top: 10%;
                color: #004a99;
                box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.2);
            }

                .jumbotron h1 {
                    font-size: 3.5rem;
                    font-weight: 900;
                    letter-spacing: -1px;
                }

            /* Glossy 2000s Era Buttons */
            .btn-azure {
                background: linear-gradient(180deg, #4da6ff 0%, #007FFF 50%, #005fbf 100%);
                color: white;
                border: 1px solid #004a99;
                border-radius: 50px;
                padding: 12px 30px;
                font-weight: bold;
                transition: all 0.3s ease;
                box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 4px 15px rgba(0,127,255,0.3);
                margin: 10px;
            }

                .btn-azure:hover {
                    transform: translateY(-2px);
                    filter: brightness(1.1);
                    color: white;
                    box-shadow: 0 6px 20px rgba(0,127,255,0.4);
                }

            .container {
                display: flex;
                justify-content: center;
                align-items: center;
            }
    </style>
</head>


<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">EVENT EASE</a>
        </div>
    </nav>

    <div class="container">
        <div class="jumbotron text-center">
            <h1>Welcome to EventEase</h1>
            <p class="lead">Dream Ahead. Book Early. Celebrate with ease.</p>
            <hr class="my-4" style="border-top: 1px solid rgba(255,255,255,0.3)">
            
            <div class="d-flex justify-content-center flex-wrap">
                <a href="/Venue" class="btn btn-azure">Venues</a>
                <a href="/Event" class="btn btn-azure">Events</a>
                <a href="/Booking" class="btn btn-azure">Bookings</a>
            </div>
        </div>
    </div>
</body>
</html>

