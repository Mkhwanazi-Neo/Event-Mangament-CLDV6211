@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<style>
    body {
        /* Keeping the background consistent */
        background: url('/images/poolroom.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #004a99;
        min-height: 100vh;
    }

    /* Glass Container for the Table */
    .glass-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 15px;
        padding: 30px;
        margin-top: 50px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
    }

    h1 {
        font-weight: 800;
        color: #007FFF;
        text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.5);
        margin-bottom: 20px;
    }

    /* Glossy 2000s Action Link */
    .btn-create {
        display: inline-block;
        background: linear-gradient(180deg, #4da6ff 0%, #007FFF 50%, #005fbf 100%);
        color: white !important;
        padding: 8px 20px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 0 4px 10px rgba(0, 127, 255, 0.3);
        transition: transform 0.2s;
    }

        .btn-create:hover {
            transform: scale(1.05);
            text-decoration: none;
        }

    /* Modern Transparent Table */
    .table {
        color: #003366;
        background: transparent;
    }

        .table thead th {
            border-top: none;
            border-bottom: 2px solid rgba(0, 127, 255, 0.2);
            color: #007FFF;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        .table td {
            vertical-align: middle;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
        }

    /* Styling the Edit/Details/Delete links */
    .action-links a {
        color: #007FFF;
        font-weight: 600;
        margin-right: 5px;
        transition: color 0.2s;
    }

        .action-links a:hover {
            color: #004a99;
            text-decoration: underline;
        }
</style>

<div class="container">
    <div class="glass-card">
        <h1>Current Bookings</h1>

        <p>
            <a asp-action="Create" class="btn-create">+ Create New Booking</a>
        </p>

        <table class="table">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.BookingID)</th>
                    <th>@Html.DisplayNameFor(model => model.Event)</th>
                    <th>@Html.DisplayNameFor(model => model.Venue)</th>
                    <th>@Html.DisplayNameFor(model => model.BookingDate)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>#@Html.DisplayFor(modelItem => item.BookingID)</strong></td>
                        <td>@Html.DisplayFor(modelItem => item.Event.EventName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Venue.Location)</td>
                        <td>@item.BookingDate.ToString("dd MMM yyyy")</td>
                        <td class="action-links">
                            <a asp-action="Edit" asp-route-id="@item.BookingID">Edit</a> |
                            <a asp-action="Details" asp-route-id="@item.BookingID">Details</a> |
                            <a asp-action="Delete" asp-route-id="@item.BookingID">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
